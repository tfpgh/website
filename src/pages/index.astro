---
import Base from "@/layouts/Base.astro";
import { Image } from "astro:assets";
import profilePhoto from "@/assets/images/profile-photo.png";

const personSchema = {
    "@context": "https://schema.org",
    "@type": "Person",
    name: "Toby Penner",
    url: Astro.site?.toString(),
    image: profilePhoto.src,
    email: "mailto:tobypenner01@gmail.com",
    alumniOf: {
        "@type": "CollegeOrUniversity",
        name: "Middlebury College",
    },
    sameAs: ["https://github.com/tfpgh", "https://linkedin.com/in/tobypenner"],
};
---

<Base
    type="home"
    baseTitle="Toby Penner"
    description="Toby Penner—computer science at Middlebury."
    jsonLD={personSchema}
>
    <div class="header">
        <Image
            src={profilePhoto}
            alt="Portrait of Toby Penner"
            width={75}
            height={75}
            densities={[1, 1.5, 2, 2.5, 3]}
            loading="eager"
        />
        <div>
            <h1>Toby Penner</h1>
            <p>
                I study computer science at Middlebury College. This summer I'm
                at
                <a href="https://comma.ai">comma.ai</a> working on machine learning
                for self-driving cars.
            </p>
            <p>
                This isn't just a website, it's a vibrant tapestry of&hellip;
                just kidding. All writing is my own—even em-dashes.
            </p>
            <div class="links">
                <a href="mailto:tobypenner01@gmail.com">Email</a>
                <a href="https://github.com/tfpgh">GitHub</a>
                <a href="https://linkedin.com/in/tobypenner">LinkedIn</a>
            </div>
        </div>
    </div>

    <hr />

    <ul class="projects">
        <li>
            <h2>Tag, You're It</h2>
            <div class="links">
                <a href="/tag" data-astro-prefetch>Writeup</a>
                <a href="https://www.youtube.com/watch?v=83YcsIVBEEk">Video</a>
                <a href="/tag/poster.pdf">Poster</a>
                <a href="https://github.com/tfpgh/tag_rl">GitHub</a>
            </div>
            <p>
                I wanted to watch robots play tag, so I built two, pitted them
                against each other in simulation for five (virtual) years, and
                transferred the policies to the real world.
            </p>
        </li>
        <li>
            <h2>comma Controls Challenge</h2>
            <div class="links">
                <a href="/comma-controls-challenge" data-astro-prefetch
                    >Writeup</a
                >
                <a href="https://github.com/tfpgh/controls_challenge">GitHub</a>
            </div>
            <p>
                My two 1st place entries. I trained a fast neural controller by
                behaviorally cloning a slow, expensive one. Then I cheated the
                RNG to predict the future.
            </p>
        </li>
    </ul>
</Base>

<style>
    .header {
        display: flex;
        align-items: flex-start;
        gap: var(--avatar-gap);
    }

    .header img {
        flex-shrink: 0;
        margin-top: 0.3rem;
        object-fit: cover;
        border-radius: 50%;
    }

    hr {
        margin: 3rem 0 3rem var(--avatar-offset);
    }

    ul {
        margin-bottom: 0;
    }

    p {
        margin-bottom: 1.5rem;
    }

    .projects {
        list-style: none;
        margin-left: var(--avatar-offset);
        padding-left: 0;
    }

    .projects li {
        margin-bottom: 2.5rem;
    }

    .projects li:last-child {
        margin-bottom: 0;
    }

    .projects h2 {
        margin-top: 0;
    }

    .projects p {
        margin-top: 0.5rem;
        margin-bottom: 0;
    }

    .links {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
    }

    @media (max-width: 800px) {
        .header {
            flex-direction: column;
        }

        .header img {
            margin-top: 0;
        }

        hr,
        .projects {
            margin-left: 0;
        }
    }
</style>
